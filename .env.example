APP_NAME="GTS Internal Tool"
APP_PORT=8080
SHARED_ACCESS_CODE=change-this-access-code
SESSION_SECRET_KEY=change-this-random-session-secret
DATABASE_PATH=data/gts_catalogue.sqlite3
MAX_UPLOAD_SIZE_MB=10
PRODUCT_EDIT_PASSWORD=change-this-edit-password
# Optional. If omitted, supplier editing uses PRODUCT_EDIT_PASSWORD.
SUPPLIER_EDIT_PASSWORD=change-this-supplier-edit-password
# Emergency legacy access code login. Keep false for normal username/password login.
ENABLE_LEGACY_ACCESS_CODE=false
