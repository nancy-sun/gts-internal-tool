APP_NAME="GTS Internal Tool"
APP_ENV=local
APP_PORT=8080
SESSION_SECRET_KEY=change-this-random-session-secret
# Local development default. If DATABASE_URL is empty, DATABASE_PATH is used.
DATABASE_PATH=data/gts_catalogue.sqlite3
# Optional local SQLite URL:
# DATABASE_URL=sqlite:///data/gts_catalogue.sqlite3
# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
MAX_UPLOAD_SIZE_MB=10
BASE_URL=http://localhost:8080
FORCE_HTTPS=false
SECURE_COOKIES=false
UPLOAD_DIR=uploads
GENERATED_DIR=generated
BACKUP_DIR=backups
# Emergency legacy access code login. Keep false for normal username/password login.
ENABLE_LEGACY_ACCESS_CODE=false
# Required only if ENABLE_LEGACY_ACCESS_CODE=true.
SHARED_ACCESS_CODE=
# Legacy fallback only. Normal sensitive writes use the logged-in user's password.
PRODUCT_EDIT_PASSWORD=
SUPPLIER_EDIT_PASSWORD=
