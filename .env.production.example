APP_NAME="GTS Internal Tool"
APP_ENV=production
APP_PORT=8080
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
SESSION_SECRET=change-this-long-random-session-secret
ENABLE_LEGACY_ACCESS_CODE=false
BASE_URL=https://internal.gtsmotor.cn
FORCE_HTTPS=true
SECURE_COOKIES=true
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/data/uploads
GENERATED_DIR=/data/generated
BACKUP_DIR=/data/backups

# Required only if ENABLE_LEGACY_ACCESS_CODE=true.
SHARED_ACCESS_CODE=

# Legacy fallback only. Normal sensitive writes use the logged-in user's password.
PRODUCT_EDIT_PASSWORD=
SUPPLIER_EDIT_PASSWORD=
